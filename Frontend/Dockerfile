FROM node:20 AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build
FROM nginx:alpine
COPY --from=build /app/dist/frontend/browser /usr/share/nginx/html
# Copy a custom nginx.conf if needed for routing, but default is fine for basic tests
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
